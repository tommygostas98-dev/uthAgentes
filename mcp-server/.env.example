# Copia a .env para correr local. NUNCA subas .env (esta en .gitignore).
# server.py carga este archivo al arrancar.

# Transporte: stdio (local, para probar) | streamable-http (deploy) | sse
MCP_TRANSPORT=stdio

# Solo para HTTP:
HOST=127.0.0.1
PORT=8000

# Token compartido: si se define, el HTTP exige Authorization: Bearer <token>.
# Genera uno con:  python -c "import secrets; print(secrets.token_urlsafe(24))"
# UTHAGENTES_TOKEN=pon-aqui-un-token-largo

# Ruta del archivo SQLite (default: data/uthagentes.db junto a server.py)
# UTHAGENTES_DB=data/uthagentes.db

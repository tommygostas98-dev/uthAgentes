{
  "_comentario": "El repo YA trae un .mcp.json en la raiz con el bloque 'uthagentes'. Solo define la variable de entorno UTHAGENTES_TOKEN (el instructor te da el token) y reabre la terminal. 'uthagentes-local' es opcional: corre tu propia copia por stdio (DB propia, NO comparte con la clase).",
  "mcpServers": {
    "uthagentes": {
      "type": "http",
      "url": "https://breeches-wing-ensnare.ngrok-free.dev/mcp",
      "headers": {
        "Authorization": "Bearer ${UTHAGENTES_TOKEN}",
        "ngrok-skip-browser-warning": "true"
      }
    },
    "uthagentes-local": {
      "command": "python",
      "args": ["mcp-server/server.py"]
    }
  }
}

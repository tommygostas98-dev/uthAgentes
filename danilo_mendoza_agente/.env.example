# Copia este archivo como ".env" y coloca tu clave real de la API de Claude.
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (opcional). Por defecto: claude-sonnet-4-6
# Opciones: claude-opus-4-8 (más potente), claude-sonnet-4-6 (equilibrado), claude-haiku-4-5-20251001 (rápido/barato)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Envío de correos (Gmail) -------------------------------------------
# Cuenta con la que se abren los botones "Abrir en Gmail" (Gmail web, authuser).
GMAIL_CUENTA=tu_cuenta@gmail.com

# Para enviar reportes y alertas por correo.
# 1) Activa la verificación en 2 pasos en la cuenta de Gmail que ENVÍA.
# 2) Genera una "Contraseña de aplicación" en: https://myaccount.google.com/apppasswords
# 3) Pega esa contraseña (16 caracteres, sin espacios) abajo.
GMAIL_USER=tu_cuenta@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Correo de destino por defecto (a dónde llegan reportes/alertas)
EMAIL_DESTINO=tu_destino@gmail.com
